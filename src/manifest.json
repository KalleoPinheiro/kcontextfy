{
  "manifest_version": 3,
  "name": "KContextify",
  "version": "0.1.0",
  "description": "Convert any webpage, video, or article into clean Markdown",
  "permissions": ["activeTab", "storage", "scripting"],
  "host_permissions": ["https://generativelanguage.googleapis.com/*"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icons/icon.svg"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "128": "icons/icon.svg"
  }
}
